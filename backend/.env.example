# --- Core ---
DATABASE_URL=sqlite:///./leadpulse_local.db
JWT_SECRET=change-me-to-something-long-for-demo-only
API_V1_PREFIX=/api/v1
PROJECT_NAME=LeadPulse AI

# Webhook hardening (optional)
WEBHOOK_SHARED_SECRET=

# --- Enrichment (Module 2) — chain: Hunter → Clearbit → ENRICHMENT_API_URL → heuristic ---
HUNTER_API_KEY=
CLEARBIT_API_KEY=
ENRICHMENT_API_URL=
ENRICHMENT_API_TIMEOUT_SECONDS=1.5

# --- Outreach (Module 4) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
HOT_OUTREACH_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- ML blend (Module 3): 0 = rules only, 1 = 100% learned head ---
ML_BLEND_WEIGHT=0.55

# --- Engagement simulation (disable when real tracking is live) ---
SYNTHETIC_ENGAGEMENT_ENABLED=true

# --- Public tracking ingest (recommended in production) ---
PUBLIC_TRACKING_SECRET=

# --- Scoring thresholds ---
HOT_SCORE_MIN=80
WARM_SCORE_MIN=50
