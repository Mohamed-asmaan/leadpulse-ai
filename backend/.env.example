# --- Core ---
DATABASE_URL=sqlite:///./leadpulse_local.db
JWT_SECRET=change-me-to-something-long-for-demo-only
API_V1_PREFIX=/api/v1
PROJECT_NAME=LeadPulse AI
ENVIRONMENT=development

# Browser origins allowed for CORS (comma-separated). Leave empty for dev wildcard.
# Example: http://localhost:3000,https://your-frontend.vercel.app
CORS_ALLOW_ORIGINS=
ALLOW_INSECURE_CORS_WILDCARD=true

# Webhook hardening (optional)
WEBHOOK_SHARED_SECRET=
REQUIRE_WEBHOOK_SECRET=false
REQUIRE_IDEMPOTENCY_FOR_WEBHOOKS=true

# Meta Lead Ads — Graph API Page webhook (same app as developers.facebook.com)
# Callback URL: {your-api}/api/v1/webhooks/meta  (GET verify + POST lead payloads)
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# Public marketing-site forms (embed script + POST website-lead)
WEBSITE_FORM_SHARED_SECRET=

# --- Enrichment (Module 2) — chain: Hunter → Clearbit → ENRICHMENT_API_URL → heuristic ---
HUNTER_API_KEY=
CLEARBIT_API_KEY=
ENRICHMENT_API_URL=
ENRICHMENT_API_TIMEOUT_SECONDS=1.5

# --- Outreach (Module 4) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
HOT_OUTREACH_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- ML blend (Module 3): 0 = rules only, 1 = 100% learned head ---
ML_BLEND_WEIGHT=0.55

# --- Engagement simulation (disable when real tracking is live) ---
SYNTHETIC_ENGAGEMENT_ENABLED=true

# --- Public tracking ingest (recommended in production) ---
PUBLIC_TRACKING_SECRET=

# API abuse control
MAX_REQUEST_BODY_BYTES=2000000
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_BURST_ALLOWANCE=30

# Security headers / transport
ENABLE_HSTS=false
HSTS_MAX_AGE_SECONDS=31536000

# Audit logging
ENABLE_AUDIT_LOGS=true

# --- Scoring thresholds ---
HOT_SCORE_MIN=80
WARM_SCORE_MIN=50
