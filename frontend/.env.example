# Local: point at your machine (or leave unset to use `/leadpulse-api` rewrite in next.config.mjs).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Production API (Render) — also set in Vercel “Environment Variables” if you override build env:
# NEXT_PUBLIC_API_URL=https://leadpulse-api-akds.onrender.com

# If NEXT_PUBLIC_API_URL is unset, `npm run dev` uses Next.js rewrite `/leadpulse-api` → http://127.0.0.1:8000
# To proxy to another port/host during dev:
# LEADPULSE_API_PROXY_TARGET=http://127.0.0.1:8000
